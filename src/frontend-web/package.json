{
  "name": "file-share-ui",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "cy": "npx cypress open",
    "serve": "serve -s dist",
    "docker:build:test": "node build-docker-test-image.cjs",
    "test:full": "docker-compose --file e2e-docker-compose.yml down && docker-compose --file e2e-docker-compose.yml up -d --remove-orphans && wait-on http://localhost:5173 && cypress run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@videojs/themes": "^1.0.1",
    "axios": "^1.11.0",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.11",
    "video.js": "^8.23.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.15.32",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/tsconfig": "^0.7.0",
    "canvas": "^3.1.2",
    "cypress": "^14.5.3",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "~10.2.0",
    "jiti": "^2.4.2",
    "jsqr": "^1.4.0",
    "npm-run-all2": "^8.0.4",
    "otplib": "^12.0.1",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "serve": "^14.2.4",
    "sharp": "^0.34.3",
    "typescript": "~5.8.0",
    "vite": "^7.0.0",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.4"
  }
}