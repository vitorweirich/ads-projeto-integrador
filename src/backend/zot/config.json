{
    "storage": {
        "rootDirectory": "/var/lib/zot"
    },
    "http": {
        "address": "0.0.0.0",
        "port": "5000",
        "compat": [
            "docker2s2"
        ],
        "auth": {
            "htpasswd": {
                "path": "/etc/zot/htpasswd"
            }
        }
    },
    "extensions": {
        "ui": {
            "enable": true
        },
        "search": {
            "enable": true
        }
    },
    "log": {
        "level": "info"
    }
}